{
  "name": "jobidocs",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:electron": "tsc -p tsconfig.electron.json && npm run copy-tray-icon && vite build",
    "preview": "vite preview",
    "electron:dev": "tsc -p tsconfig.electron.json && npm run copy-tray-icon && concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:electron && electron-builder",
    "api:dev": "tsx watch api/server.ts",
    "copy-tray-icon": "cp electron/tray-icon.png dist-electron/electron/"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
