{
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fastify/cors": "^10.0.1",
    "@supabase/supabase-js": "^2.45.0",
    "electron-updater": "^6.3.9",
    "fastify": "^5.1.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "main": "dist-electron/electron/main.js",
  "name": "jobidocs",
  "private": true,
  "scripts": {
    "api:dev": "tsx watch api/server.ts",
    "build": "tsc && vite build && electron-builder",
    "build:electron": "npm run copy-app-icon && tsc -p tsconfig.electron.json && npm run copy-tray-icon && vite build",
    "copy-app-icon": "mkdir -p public/logos && cp \"../logos/jdlogo.png\" electron/icon.png && cp \"../logos/jdlogo.png\" public/logos/jdlogo.png && cp \"../logos/trayicon-black.png\" electron/tray-icon-template.png",
    "copy-tray-icon": "cp electron/tray-icon-template.png dist-electron/electron/",
    "dev": "vite",
    "electron:build": "npm run build:electron && electron-builder",
    "electron:build:universal": "npm run build:electron && electron-builder --mac --universal",
    "electron:dev": "npm run copy-app-icon && tsc -p tsconfig.electron.json && npm run copy-tray-icon && concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "preview": "vite preview"
  },
  "version": "0.2.2"
}