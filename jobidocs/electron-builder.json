      { "x": 130, "y": 220, "type": "file" },
      { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
    ]
  },
  "win": { "target": ["nsis", "portable"] },
  "publish": { "provider": "github", "owner": "alexpapillier-lab", "repo": "jobi" }
