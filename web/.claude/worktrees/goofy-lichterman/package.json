{
  "name": "jobi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:check": "concurrently \"vite\" \"tsc --noEmit --watch\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=9999",
    "build": "npm run typecheck && npm run lint && vite build",
    "build:prod": "npm run typecheck && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev:check": "concurrently \"npm run tauri dev\" \"tsc --noEmit --watch\"",
    "tauri:build": "npm run build:prod && tauri build",
    "tauri:build:universal": "bash scripts/build-universal.sh",
    "tauri:build:universal:signed": "bash scripts/build-universal-signed.sh",
    "generate-latest-json": "bash scripts/generate-jobi-latest-json.sh",
    "gen-dmg-background": "node scripts/gen-dmg-background.js",
    "build:all": "bash scripts/build-jobi-and-jobidocs.sh",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-http": "2.5.7",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "postcss": "^8.5.6",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.51.0",
    "vite": "^7.0.4",
    "vitest": "^4.0.18"
  }
}
