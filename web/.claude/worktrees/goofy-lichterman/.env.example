# Pro testovací i finální verzi můžeš použít stejný projekt (doporučeno, viz docs/TEST_VERSION_PLAN.md).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Root owner – UUID z Auth (Dashboard → Authentication → Users). Pokud nastaveno, tento uživatel vidí všechny servisy a v seznamech týmu se nikde nezobrazuje.
# VITE_ROOT_OWNER_ID=

# --- E-mail pozvánky (Resend) – nastavuje se v Supabase, ne v .env ---
# V Supabase Dashboard: Project → Edge Functions → Secrets (nebo Settings → Edge Functions → Secrets).
# RESEND_API_KEY   – povinné pro odesílání e-mailů s kódem pozvánky (bez něj se pozvánka vytvoří, ale mail neodešle).
# RESEND_FROM_EMAIL – volitelné, výchozí: "Jobi <onboarding@resend.dev>" (pro ostatní adresy ověř doménu v Resend a nastav např. "Jobi <invite@appjobi.com>").
# RESEND_FROM_EMAIL_PASSWORD_RESET – volitelné; pokud je nastaveno, e-maily pro obnovu hesla jdou z této adresy (např. "Jobi <resetpassword@appjobi.com>"). Jinak se použije RESEND_FROM_EMAIL.
# RESEND_LOGO_URL – volitelné, výchozí: "https://appjobi.com/logo.png" (veřejná URL obrázku loga v e-mailu pozvánky).
